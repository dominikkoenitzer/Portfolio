# Normalize line endings: store as LF in the repo, check out LF everywhere.
# Stops the "LF will be replaced by CRLF" churn on Windows checkouts.
* text=auto eol=lf

# Generated / lockfiles — keep out of diffs and language stats.
bun.lock -diff linguist-generated

# Binary assets — never normalize or diff.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.pdf  binary
*.exe  binary
