# Copy to `.env` on the VPS and fill in. Never commit the real .env.

# --- SMTP relay (authenticate to an existing mailbox; do NOT send raw from the
# VPS IP or mail will land in spam). Use your domain mailbox's SMTP, or a Gmail
# App Password (Google account → Security → 2-Step Verification → App passwords).
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false                     # set "true" only if you use port 465
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-smtp-password-or-app-password

# --- Mail routing
MAIL_FROM="Portfolio <you@yourdomain.com>"   # usually the same as SMTP_USER
MAIL_TO=dominik.koenitzer@gmail.com          # where inquiries are delivered

# --- Web
# The exact origin of your site. The browser only lets the form POST here if
# this matches (CORS). No trailing slash.
ALLOWED_ORIGIN=https://dominikkoenitzer.ch
PORT=8080
